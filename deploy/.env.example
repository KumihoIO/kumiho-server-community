# Copy to `.env` (same directory). The launchers pass it to docker compose, so
# these values reach Neo4j/Redis regardless of how the launcher is started.
#
#   cp .env.example .env
#
# REQUIRED: set this to the SAME Neo4j password you entered in
# `kumiho_server onboard` (stored as db_pass in ~/.kumiho/server.toml). If they
# differ, the server cannot authenticate to Neo4j. Applied on first volume init.
KUMIHO_NEO4J_PASSWORD=kumihotest

# Only change these if you chose NON-DEFAULT ports in onboarding. They are the
# host (loopback) ports the server connects to, and must equal neo4j_port /
# redis_port in ~/.kumiho/server.toml.
KUMIHO_NEO4J_PORT=7687
KUMIHO_REDIS_PORT=6379
